---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import MagicLink from '@/components/content/magic-link.astro'
import MermaidIsland from '@/components/content/mermaid-island.astro'
import ProseLayout from '@/components/content/prose-layout.astro'
import RubyAnnotation from '@/components/content/ruby-annotation.astro'
import Toc from '@/components/content/toc.astro'
import BaseLayout from '@/layouts/base-layout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map((post: CollectionEntry<'posts'>) => ({
    params: {
      slug: post.id,
    },
    props: {
      post,
    },
  }))
}

const { post } = Astro.props as {
  post: CollectionEntry<'posts'>
}
const { Content, headings } = await render(post)
const pageTitle = post.data.title || `${post.id} - octohash`
const postOgImage = `/posts/${post.id}/og.png`
---

<BaseLayout title={pageTitle} ogImage={postOgImage} layout="wide">
  <ProseLayout frontmatter={post.data} backPath="/posts">
    <Toc slot="toc" headings={headings} />
    <Content components={{ Mermaid: MermaidIsland, MagicLink, RubyAnnotation }} />
  </ProseLayout>
</BaseLayout>
